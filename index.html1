<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Nexora AI - Quality Education</title>

<style>
body{
  margin:0;
  font-family:Arial, sans-serif;
  background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);
  color:white;
}

/* HERO */
.hero{
  text-align:center;
  padding:100px 20px;
}

.hero h1{
  font-size:3.2rem;
  background:linear-gradient(90deg,#00c6ff,#7f00ff);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.hero p{
  font-size:1.2rem;
  opacity:0.8;
}

/* SECTION */
.section{
  padding:60px 20px;
  text-align:center;
}

h2{
  margin-bottom:20px;
}

/* CARDS */
.cards{
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
  gap:15px;
}

.card{
  background:#1b1b3a;
  padding:20px;
  border-radius:12px;
  width:200px;
  transition:0.3s;
}

.card:hover{
  transform:scale(1.05);
  background:#2a2a5a;
}

/* INPUT */
input{
  padding:12px;
  width:80%;
  max-width:400px;
  border:none;
  border-radius:10px;
}

/* FOOTER */
footer{
  text-align:center;
  padding:20px;
  background:#000;
}
</style>
</head>

<body>

<!-- HERO -->
<div class="hero">
  <h1>NEXORA AI</h1>
  <p>Future of Quality Education with AI-Powered Learning</p>
</div>

<!-- FEATURES -->
<div class="section">
  <h2>Features</h2>
  <div class="cards">
    <div class="card">🤖 AI Learning Assistant</div>
    <div class="card">📊 Progress Tracker</div>
    <div class="card">🎯 Personalized Learning</div>
    <div class="card">💙 Student Wellness</div>
    <div class="card">🌍 Multilingual Support</div>
  </div>
</div>

<!-- AI SECTION -->
<div class="section">
  <h2>Ask Nexora AI</h2>
  <p>Type your question below</p>
  <input placeholder="Ask anything..." />
</div>

<!-- FOOTER -->
<footer>
  © 2026 Nexora AI | Quality Education Project
</footer>

</body>
  </html>
